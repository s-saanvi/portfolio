---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config";
---

<BaseLayout title="Contact Us">
  <div class="py-12 md:py-24 max-w-3xl mx-auto">
    <div class="mb-12 text-center">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tighter uppercase mb-6" style={`text-shadow: 4px 4px 0px ${siteConfig.accentColor};`}>
        Let's Talk
      </h1>
      <p class="text-xl font-medium">
        Ready to start your next project? Drop us a message.
      </p>
    </div>

    <form class="neo-box p-8 md:p-12 bg-white space-y-6" onsubmit="event.preventDefault();">
      <div class="space-y-2">
        <label for="name" class="block font-bold uppercase text-sm">Full Name</label>
        <input
          type="text"
          id="name"
          name="name"
          class="w-full border-3 border-black p-4 font-medium focus:outline-none focus:ring-4 focus:ring-black focus:border-black transition-shadow"
          style={`focus:ring-color: ${siteConfig.accentColor}`}
          placeholder="Jules Tech"
          required
        />
      </div>

      <div class="space-y-2">
        <label for="email" class="block font-bold uppercase text-sm">Email Address</label>
        <input
          type="email"
          id="email"
          name="email"
          class="w-full border-3 border-black p-4 font-medium focus:outline-none focus:ring-4 focus:ring-black transition-shadow"
          placeholder="hello@example.com"
          required
        />
      </div>

      <div class="space-y-2">
        <label for="message" class="block font-bold uppercase text-sm">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          class="w-full border-3 border-black p-4 font-medium focus:outline-none focus:ring-4 focus:ring-black transition-shadow resize-y"
          placeholder="Tell us about your project..."
          required
        ></textarea>
      </div>

      <button
        type="submit"
        class="neo-button w-full py-4 text-white text-xl mt-4"
        style={`background-color: ${siteConfig.accentColor}`}
      >
        Send Message
      </button>
    </form>

    <div class="mt-12 text-center">
      <p class="font-bold uppercase text-sm mb-2">Or email us directly</p>
      <a href={`mailto:${siteConfig.social.email}`} class="text-2xl font-black hover:underline decoration-4" style={`text-decoration-color: ${siteConfig.accentColor}`}>
        {siteConfig.social.email}
      </a>
    </div>
  </div>
</BaseLayout>
