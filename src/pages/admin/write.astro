---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../config";

const authCookie = Astro.cookies.get("admin-auth");
if (!authCookie || authCookie.value !== "true") {
  return Astro.redirect(import.meta.env.BASE_URL + "admin/login");
}
---

<BaseLayout title="Write Post">
  <div class="py-12 md:py-24 max-w-4xl mx-auto">
    <div class="mb-12 text-center">
      <h1 class="text-5xl md:text-6xl font-bold tracking-tighter uppercase mb-6" style={`text-shadow: 4px 4px 0px ${siteConfig.accentColor};`}>
        Write a Post
      </h1>
      <p class="text-xl font-medium">
        Draft your new blog entry below.
      </p>
    </div>

    <form id="write-form" class="neo-box p-8 md:p-12 bg-white space-y-6">
      <div class="space-y-2">
        <label for="title" class="block font-bold uppercase text-sm">Post Title</label>
        <input
          type="text"
          id="title"
          name="title"
          class="w-full border-3 border-black p-4 font-medium focus:outline-none focus:ring-4 focus:ring-black transition-shadow"
          style={`focus:ring-color: ${siteConfig.accentColor}`}
          placeholder="My Awesome Blog Post"
          required
        />
      </div>

      <div class="space-y-2">
        <label for="summary" class="block font-bold uppercase text-sm">Short Summary</label>
        <input
          type="text"
          id="summary"
          name="summary"
          class="w-full border-3 border-black p-4 font-medium focus:outline-none focus:ring-4 focus:ring-black transition-shadow"
          placeholder="A brief description of this post..."
          required
        />
      </div>

      <div class="space-y-2">
        <label for="content" class="block font-bold uppercase text-sm">Content (Markdown supported)</label>
        <textarea
          id="content"
          name="content"
          rows="10"
          class="w-full border-3 border-black p-4 font-medium focus:outline-none focus:ring-4 focus:ring-black transition-shadow resize-y"
          placeholder="Start writing..."
          required
        ></textarea>
      </div>

      <div class="flex justify-end gap-4 mt-8">
        <a
          href={import.meta.env.BASE_URL + "blog"}
          class="neo-button px-8 py-4 bg-gray-200 text-black text-xl hover:bg-gray-300"
        >
          Cancel
        </a>
        <button
          type="submit"
          class="neo-button px-8 py-4 text-white text-xl"
          style={`background-color: ${siteConfig.accentColor}`}
        >
          Publish Post
        </button>
      </div>
    </form>
  </div>
</BaseLayout>

<script>
  const writeForm = document.getElementById('write-form');

  writeForm?.addEventListener('submit', (e) => {
    e.preventDefault();

    // In a real application, you would send the data to a server here.
    // For this mock, we just alert success and redirect.
    alert('Post successfully published! (Mock behavior)');

    // Redirect to the blog listing page
    window.location.href = import.meta.env.BASE_URL + 'blog';
  });
</script>
