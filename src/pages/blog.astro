---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config";
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
// Sort posts by date descending
allPosts.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---

<BaseLayout title="Blog">
  <div class="py-12 md:py-24">
    <div class="mb-16 flex justify-between items-end flex-wrap gap-4">
      <div>
        <h1 class="text-5xl md:text-7xl font-bold tracking-tighter uppercase mb-4" style={`text-shadow: 4px 4px 0px ${siteConfig.accentColor};`}>
          The Blog
        </h1>
        <div class="w-32 h-4 bg-black"></div>
      </div>
      <p class="text-lg font-bold uppercase bg-black text-white px-4 py-2">
        Thoughts & Updates
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      {allPosts.map((post) => (
        <article class="neo-box bg-white flex flex-col group relative">
          <div class="h-48 border-b-3 border-black bg-gray-100 flex items-center justify-center relative overflow-hidden">
             {post.data.image ? (
               <img src={`${import.meta.env.BASE_URL}${post.data.image.replace(/^\//, '')}`} alt={post.data.title} class="w-full h-full object-cover" />
             ) : (
               <div class="absolute inset-0 opacity-20" style={`background-image: radial-gradient(${siteConfig.accentColor} 2px, transparent 2px); background-size: 16px 16px;`}></div>
             )}
             {!post.data.image && <span class="text-4xl font-black opacity-30 group-hover:scale-110 transition-transform">POST</span>}
          </div>
          <div class="p-8 flex flex-col flex-grow">
            <div class="text-sm font-bold border-2 border-black inline-block px-2 py-1 mb-4 self-start bg-yellow-300">
              {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </div>
            <h2 class="text-3xl font-bold uppercase mb-4 leading-tight group-hover:text-gray-700 transition-colors">
              <a href={`${import.meta.env.BASE_URL}blog/${post.slug}`} class="before:absolute before:inset-0">
                {post.data.title}
              </a>
            </h2>
            <p class="font-medium flex-grow text-gray-800">
              {post.data.summary}
            </p>
            <div class="mt-8">
              <span class="font-bold uppercase tracking-wider text-sm border-b-2 border-black pb-1">Read More</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
