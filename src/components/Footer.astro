---
import { siteConfig } from "../config";
const base = import.meta.env.BASE_URL;
---

<footer class="mt-24 border-t-4 border-black bg-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-8 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="neo-box p-6 bg-gray-50">
      <h3 class="text-xl font-bold uppercase mb-4" style={`color: ${siteConfig.accentColor}`}>CodingCup Labs</h3>
      <p class="font-medium text-sm">Building bold and innovative digital solutions. Let's make something awesome together.</p>
    </div>

    <div class="neo-box p-6 bg-white">
      <h3 class="text-xl font-bold uppercase mb-4">Quick Links</h3>
      <ul class="space-y-2 font-bold text-sm uppercase">
        <li><a href={`${base}/about`} class="hover:underline">About</a></li>
        <li><a href={`${base}/services`} class="hover:underline">Services</a></li>
        <li><a href={`${base}/blog`} class="hover:underline">Blog</a></li>
        <li><a href={`${base}/contact`} class="hover:underline">Contact</a></li>
      </ul>
    </div>

    <div class="neo-box p-6" style={`background-color: ${siteConfig.accentColor}; color: white;`}>
      <h3 class="text-xl font-bold uppercase mb-4 text-white">Find Us</h3>
      <div class="flex gap-4">
        {siteConfig.social.twitter && <a href={siteConfig.social.twitter} class="neo-button px-3 py-1 bg-white text-black" target="_blank">TW</a>}
        {siteConfig.social.github && <a href={siteConfig.social.github} class="neo-button px-3 py-1 bg-white text-black" target="_blank">GH</a>}
        {siteConfig.social.linkedin && <a href={siteConfig.social.linkedin} class="neo-button px-3 py-1 bg-white text-black" target="_blank">IN</a>}
      </div>
      <p class="mt-4 font-bold text-sm break-all">{siteConfig.social.email}</p>
    </div>
  </div>

  <div class="text-center font-bold text-sm mt-12 uppercase">
    © {new Date().getFullYear()} {siteConfig.name}. Built with Astro.
  </div>
</footer>
