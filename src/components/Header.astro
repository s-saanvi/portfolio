---
import { siteConfig } from "../config";
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 border-b-4 border-black bg-white transition-all duration-300 shadow-[0px_4px_0px_0px_rgba(0,0,0,1)]"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-8 py-4 flex justify-between items-center">
    <a href="/" class="text-2xl font-bold tracking-tighter" style={`color: ${siteConfig.accentColor}; text-shadow: 2px 2px 0px black;`}>
      {siteConfig.name}
    </a>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="md:hidden neo-button px-3 py-1 bg-white" aria-label="Toggle menu">
      ☰
    </button>

    <!-- Desktop Navigation -->
    <ul class="hidden md:flex items-center gap-6 font-bold uppercase text-sm">
      <li><a href="/" class="hover:underline decoration-4 underline-offset-4" style={`text-decoration-color: ${siteConfig.accentColor}`}>Home</a></li>
      <li><a href="/about" class="hover:underline decoration-4 underline-offset-4" style={`text-decoration-color: ${siteConfig.accentColor}`}>About</a></li>
      <li><a href="/services" class="hover:underline decoration-4 underline-offset-4" style={`text-decoration-color: ${siteConfig.accentColor}`}>Services</a></li>
      <li><a href="/blog" class="hover:underline decoration-4 underline-offset-4" style={`text-decoration-color: ${siteConfig.accentColor}`}>Blog</a></li>
      <li><a href="/socials" class="hover:underline decoration-4 underline-offset-4" style={`text-decoration-color: ${siteConfig.accentColor}`}>Socials</a></li>
      <li>
        <a
          href="/contact"
          class="neo-button px-6 py-2 text-white"
          style={`background-color: ${siteConfig.accentColor}`}
        >
          Contact Us
        </a>
      </li>
    </ul>
  </nav>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden border-t-4 border-black bg-white">
    <ul class="flex flex-col font-bold uppercase text-center">
      <li class="border-b-2 border-black"><a href="/" class="block py-4 hover:bg-gray-100">Home</a></li>
      <li class="border-b-2 border-black"><a href="/about" class="block py-4 hover:bg-gray-100">About</a></li>
      <li class="border-b-2 border-black"><a href="/services" class="block py-4 hover:bg-gray-100">Services</a></li>
      <li class="border-b-2 border-black"><a href="/blog" class="block py-4 hover:bg-gray-100">Blog</a></li>
      <li class="border-b-2 border-black"><a href="/socials" class="block py-4 hover:bg-gray-100">Socials</a></li>
      <li>
        <a href="/contact" class="block py-4 text-white" style={`background-color: ${siteConfig.accentColor}`}>
          Contact Us
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
